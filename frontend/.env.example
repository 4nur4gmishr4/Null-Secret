# ─── Null-Secret Frontend Environment ───
# Copy this file to .env.local for local development
# or set these as Vercel project environment variables for production.

# Where the Go backend is reachable.
# Local dev:   http://localhost:8080/api/v1
# Production:  https://<your-render-app>.onrender.com/api/v1
VITE_API_BASE=http://localhost:8080/api/v1

# Firebase config. Create a project at https://console.firebase.google.com
# then copy these from "Project settings → Your apps → SDK setup".
# All six are required when the app is built in production mode.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

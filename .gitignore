# ─────────────────────────────────────────────────────────────
# Build output & compiled binaries
# ─────────────────────────────────────────────────────────────
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
*.out
*.tsbuildinfo
*.stackdump

# Go
go.work
go.work.sum
vendor/

# Node / bundler output
node_modules/
dist/
dist-ssr/
build/
out/
.next/
.nuxt/
.turbo/
.vite/
.cache/
.parcel-cache/
.rollup.cache/

# PWA / Workbox generated
**/sw.js
**/workbox-*.js
!frontend/src/**/sw.js

# ─────────────────────────────────────────────────────────────
# Environment & secrets
#   .env.example IS committed so contributors can bootstrap.
# ─────────────────────────────────────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key
!**/*.pub.key
secrets.json
.credentials/

# ─────────────────────────────────────────────────────────────
# Databases & backups (runtime state, never committed)
# ─────────────────────────────────────────────────────────────
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3
backup.db
dump.rdb

# ─────────────────────────────────────────────────────────────
# IDE / editor
# ─────────────────────────────────────────────────────────────
.idea/
.vscode/
!.vscode/extensions.json
!.vscode/settings.json.sample
*.swp
*.swo
*~
*.sublime-project
*.sublime-workspace
.project
.classpath
.settings/

# ─────────────────────────────────────────────────────────────
# Operating system
# ─────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini
$RECYCLE.BIN/

# ─────────────────────────────────────────────────────────────
# Logs
# ─────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ─────────────────────────────────────────────────────────────
# Testing & coverage
# ─────────────────────────────────────────────────────────────
coverage/
*.lcov
.nyc_output/
test-results/
playwright-report/
playwright/.cache/
junit.xml

# ─────────────────────────────────────────────────────────────
# TypeScript / JS tooling
# ─────────────────────────────────────────────────────────────
*.tgz
.eslintcache
.stylelintcache
.tsbuildinfo

# ─────────────────────────────────────────────────────────────
# Misc
# ─────────────────────────────────────────────────────────────
*.pid
*.seed
*.pid.lock
tmp/
temp/
.history/

# ─────────────────────────────────────────────────────────────
# Allow-list overrides
# ─────────────────────────────────────────────────────────────
!.gitkeep
